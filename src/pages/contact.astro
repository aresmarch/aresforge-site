---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact | AresForge">
  <section class="page-hero">
    <h1>Let's Build Together</h1>
    <p>Have a project in mind or just want to explore what's possible? Reach out and we'll get back to you within 24 hours.</p>
  </section>

  <section class="contact-content">
    <div class="contact-grid">

      <!-- Contact Form -->
      <div class="contact-form-wrap">
        <h2>Send a Message</h2>
        <form class="contact-form" action="https://formspree.io/f/YOUR_FORM_ID" method="POST">
          <div class="field">
            <label for="name">Name</label>
            <input type="text" id="name" name="name" placeholder="Your name" required />
          </div>
          <div class="field">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" placeholder="your@email.com" required />
          </div>
          <div class="field">
            <label for="subject">What do you need?</label>
            <select id="subject" name="subject">
              <option value="">Select a service...</option>
              <option value="ai-automation">AI Workflow Automation</option>
              <option value="context-persistence">Context Persistence / Agent Memory</option>
              <option value="api-integration">API & Integration Development</option>
              <option value="custom-software">Custom Software Development</option>
              <option value="other">Not sure yet</option>
            </select>
          </div>
          <div class="field">
            <label for="message">Message</label>
            <textarea id="message" name="message" rows="5" placeholder="Tell us about your project..." required></textarea>
          </div>
          <button type="submit" class="cta submit-btn">Send Message</button>
        </form>
      </div>

      <!-- Contact Info -->
      <div class="contact-info">
        <h2>Or Reach Out Directly</h2>

        <div class="info-item">
          <span class="info-icon">📧</span>
          <div>
            <p class="info-label">Email</p>
            <a href="mailto:william@aresforge.dev">william@aresforge.dev</a>
          </div>
        </div>

        <div class="info-item">
          <span class="info-icon">🌐</span>
          <div>
            <p class="info-label">Website</p>
            <a href="https://aresforge.dev">aresforge.dev</a>
          </div>
        </div>

        <div class="info-card">
          <h3>Free Consultation</h3>
          <p>Not sure where to start? Book a free 30-minute call. We'll assess your workflow, identify the highest-impact automation opportunities, and give you a clear action plan — no commitment required.</p>
        </div>
      </div>

    </div>
  </section>
</Layout>

<style>
  .page-hero {
    text-align: center;
    padding: 5rem 2rem 3rem;
    max-width: 1100px;
    margin: 0 auto;
  }
  .page-hero h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    margin-bottom: 1rem;
    letter-spacing: -1px;
  }
  .page-hero p {
    color: var(--muted);
    font-size: 1.1rem;
    max-width: 600px;
    margin: 0 auto;
  }

  .contact-content {
    max-width: 1100px;
    margin: 0 auto;
    padding: 2rem 2rem 5rem;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
  }

  @media (max-width: 768px) {
    .contact-grid { grid-template-columns: 1fr; }
  }

  /* Form */
  .contact-form-wrap h2,
  .contact-info h2 {
    font-size: 1.2rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
    color: var(--accent);
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  label {
    font-size: 0.875rem;
    color: var(--muted);
    font-weight: 500;
  }

  input, select, textarea {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.75rem 1rem;
    color: var(--text);
    font-size: 0.95rem;
    font-family: inherit;
    transition: border-color 0.2s;
    outline: none;
    width: 100%;
  }

  input:focus, select:focus, textarea:focus {
    border-color: var(--accent);
  }

  input::placeholder, textarea::placeholder {
    color: var(--muted);
    opacity: 0.6;
  }

  select option {
    background: var(--surface);
    color: var(--text);
  }

  textarea { resize: vertical; }

  .submit-btn {
    width: 100%;
    border: none;
    cursor: pointer;
    font-family: inherit;
    font-size: 1rem;
  }

  /* Contact Info */
  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .info-item {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.25rem;
    transition: border-color 0.2s;
  }
  .info-item:hover { border-color: var(--accent); }

  .info-icon { font-size: 1.4rem; flex-shrink: 0; }

  .info-label {
    font-size: 0.8rem;
    color: var(--muted);
    margin-bottom: 0.25rem;
  }

  .info-item a {
    font-size: 0.95rem;
    font-weight: 500;
  }

  .info-card {
    background: var(--surface);
    border: 1px solid var(--accent);
    border-radius: 12px;
    padding: 1.75rem;
  }

  .info-card h3 {
    font-size: 1.05rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
  }

  .info-card p {
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.8;
  }
</style>